DROP DATABASE IF EXISTS biblioteka1;
CREATE DATABASE biblioteka1;
USE biblioteka1;

CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    vards VARCHAR(50),
    uzvards VARCHAR(50),
    login VARCHAR(50) UNIQUE,
    parole VARCHAR(50),
    role ENUM('student', 'teacher', 'admin') DEFAULT 'student'
);

CREATE TABLE books (
    id INT AUTO_INCREMENT PRIMARY KEY,
    virsraksts VARCHAR(255),
    autors VARCHAR(255),
    zanrs VARCHAR(100),
    saturs LONGTEXT,
    attels VARCHAR(255) DEFAULT 'default_book.jpg'
);

